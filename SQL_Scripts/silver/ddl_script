/*
===============================================================================
DDL Script: Create Silver Tables
===============================================================================
*/

-- 1. CUSTOMERS
IF OBJECT_ID('silver.customers', 'U') IS NOT NULL DROP TABLE silver.customers;
GO
CREATE TABLE silver.customers (
    customer_id              VARCHAR(20) PRIMARY KEY,
    customer_name            VARCHAR(100),
    customer_type            VARCHAR(50),
    credit_term_days         INT,             
    primary_freight_type     VARCHAR(50),
    account_status           VARCHAR(20),
    contract_start_date      DATE, 
    annual_revenue_potential DECIMAL(18, 2)   
);
GO

-- 2. DELIVERY EVENTS
IF OBJECT_ID('silver.delivery_events', 'U') IS NOT NULL DROP TABLE silver.delivery_events;
GO
CREATE TABLE silver.delivery_events (
    event_id           VARCHAR(20) PRIMARY KEY,
    load_id            VARCHAR(20),
    trip_id            VARCHAR(20),
    event_type         VARCHAR(50),
    facility_id        VARCHAR(20),
    scheduled_datetime VARCHAR(50), 
    actual_datetime    VARCHAR(50), 
    detention_minutes  INT,
    on_time_flag       BIT,            
    location_city      VARCHAR(100),
    location_state     VARCHAR(2)
);
GO

-- 3. DRIVER MONTHLY METRICS
IF OBJECT_ID('silver.driver_monthly_metrics', 'U') IS NOT NULL DROP TABLE silver.driver_monthly_metrics;
GO
CREATE TABLE silver.driver_monthly_metrics (
    driver_id             VARCHAR(20),
    month_start_date      DATE, 
    month_name            DATE,
    trips_completed       INT,
    total_miles           DECIMAL(18, 2),
    total_revenue         DECIMAL(18, 2),
    average_mpg           DECIMAL(5, 2),
    total_fuel_gallons    DECIMAL(18, 2),
    on_time_delivery_rate DECIMAL(10, 4),
    average_idle_hours    DECIMAL(10, 4),
    PRIMARY KEY (driver_id, month_start_date)
);
GO

-- 4. DRIVERS
IF OBJECT_ID('silver.drivers', 'U') IS NOT NULL DROP TABLE silver.drivers;
GO
CREATE TABLE silver.drivers (
    driver_id          VARCHAR(20) PRIMARY KEY,
    first_name         VARCHAR(50),
    last_name          VARCHAR(50),
    hire_date          DATE,
    termination_date   DATE,
    license_number     VARCHAR(50),
    license_state      VARCHAR(2),
    date_of_birth      DATE,
    home_terminal      VARCHAR(100),
    employment_status  VARCHAR(20),
    cdl_class          VARCHAR(5),
    years_experience   TINYINT 
);
GO


-- 5. FACILITIES (Adding this just in case)
IF OBJECT_ID('silver.facilities', 'U') IS NOT NULL DROP TABLE silver.facilities;
GO
CREATE TABLE silver.facilities (
    facility_id           VARCHAR(20) PRIMARY KEY,
    facility_name         VARCHAR(100),
    facility_type         VARCHAR(50),
    city                  VARCHAR(100),
    state                 VARCHAR(2),
    latitude              DECIMAL(9, 6),
    longitude             DECIMAL(9, 6),
    dock_doors            INT,
    operating_hours       VARCHAR(100)
);
GO


-- 6. FUEL PURCHASES
IF OBJECT_ID('silver.fuel_purchases', 'U') IS NOT NULL DROP TABLE silver.fuel_purchases;
GO
CREATE TABLE silver.fuel_purchases (
    fuel_purchase_id  VARCHAR(20) PRIMARY KEY,
    trip_id           VARCHAR(20),
    truck_id          VARCHAR(20),
    driver_id         VARCHAR(20),
    purchase_date     DATETIME, 
    location_city     VARCHAR(100),
    location_state    VARCHAR(2),
    gallons           DECIMAL(10, 2),
    price_per_gallon  DECIMAL(10, 4), 
    total_cost        DECIMAL(18, 2),
    fuel_card_number  VARCHAR(50)
);
GO


-- 7. LOADS
IF OBJECT_ID('silver.loads', 'U') IS NOT NULL DROP TABLE silver.loads;
GO
CREATE TABLE silver.loads (
    load_id                VARCHAR(20) PRIMARY KEY,
    customer_id            VARCHAR(20),
    route_id               VARCHAR(20),
    load_date              DATE,           
    load_type              VARCHAR(50),
    weight_lbs             DECIMAL(10, 2), 
    pieces                 INT,
    revenue                DECIMAL(18, 2),
    fuel_surcharge         DECIMAL(18, 2),
    accessorial_charges    DECIMAL(18, 2),
    load_status            VARCHAR(20),
    booking_type           VARCHAR(20)
);
GO


-- 8. MAINTENANCE RECORDS
IF OBJECT_ID('silver.maintenance_records', 'U') IS NOT NULL DROP TABLE silver.maintenance_records;
GO
CREATE TABLE silver.maintenance_records (
    maintenance_id       VARCHAR(20) PRIMARY KEY,
    truck_id             VARCHAR(20),
    maintenance_date     DATE,
    maintenance_type     VARCHAR(50),
    odometer_reading     INT,               
    labor_hours          DECIMAL(10, 2),
    labor_cost           DECIMAL(18, 2),
    parts_cost           DECIMAL(18, 2),
    total_cost           DECIMAL(18, 2),
    facility_location    VARCHAR(100),
    downtime_hours       DECIMAL(10, 2),
    service_description  VARCHAR(MAX) 
);
GO


-- 9. ROUTES
IF OBJECT_ID('silver.routes', 'U') IS NOT NULL DROP TABLE silver.routes;
GO
CREATE TABLE silver.routes (
    route_id                  VARCHAR(20) PRIMARY KEY,
    origin_city               VARCHAR(100),
    origin_state              VARCHAR(2),
    destination_city          VARCHAR(100),
    destination_state         VARCHAR(2),
    typical_distance_miles    DECIMAL(10, 2),
    base_rate_per_mile        DECIMAL(10, 2),
    fuel_surcharge_rate       DECIMAL(10, 4), 
    typical_transit_days      INT
);
GO


-- 10. SAFETY INCIDENTS
IF OBJECT_ID('silver.safety_incidents', 'U') IS NOT NULL DROP TABLE silver.safety_incidents;
GO
CREATE TABLE silver.safety_incidents (
    incident_id          VARCHAR(20) PRIMARY KEY,
    trip_id              VARCHAR(20),
    truck_id             VARCHAR(20),
    driver_id            VARCHAR(20),
    incident_date        DATE,
    incident_type        VARCHAR(50),
    location_city        VARCHAR(100),
    location_state       VARCHAR(2),
    at_fault_flag        BIT, 
    injury_flag          BIT,
    vehicle_damage_cost  DECIMAL(18, 2),
    cargo_damage_cost    DECIMAL(18, 2),
    claim_amount         DECIMAL(18, 2),
    preventable_flag     BIT,
    description          VARCHAR(MAX)
);
GO


-- 11. TRAILERS
IF OBJECT_ID('silver.trailers', 'U') IS NOT NULL DROP TABLE silver.trailers;
GO
CREATE TABLE silver.trailers (
    trailer_id            VARCHAR(20) PRIMARY KEY,
    trailer_number        VARCHAR(20),
    trailer_type          VARCHAR(50),
    length_feet           INT,
    model_year            INT,
    vin                   VARCHAR(50),
    acquisition_date      DATE,
    status                VARCHAR(20),
    current_location      VARCHAR(100)
);
GO


-- 12. TRIPS
IF OBJECT_ID('silver.trips', 'U') IS NOT NULL DROP TABLE silver.trips;
GO
CREATE TABLE silver.trips (
    trip_id                VARCHAR(20) PRIMARY KEY,
    load_id                VARCHAR(20),
    driver_id              VARCHAR(20),
    truck_id               VARCHAR(20),
    trailer_id             VARCHAR(20),
    dispatch_date          DATE,
    actual_distance_miles  DECIMAL(10, 2),
    actual_duration_hours  DECIMAL(10, 2),
    fuel_gallons_used      DECIMAL(10, 2),
    average_mpg            DECIMAL(5, 2),
    idle_time_hours        DECIMAL(10, 2),
    trip_status            VARCHAR(20)
);
GO


-- 13. TRUCK UTILIZATION METRICS
IF OBJECT_ID('silver.truck_utilization_metrics', 'U') IS NOT NULL DROP TABLE silver.truck_utilization_metrics;
GO
CREATE TABLE silver.truck_utilization_metrics (
    truck_id            VARCHAR(20),
    month_start_date    DATE,      
    month_name          VARCHAR (15),
    trips_completed     INT,
    total_miles         DECIMAL(18, 2),
    total_revenue       DECIMAL(18, 2),
    average_mpg         DECIMAL(5, 2),
    maintenance_events  INT,
    maintenance_cost    DECIMAL(18, 2),
    downtime_hours      DECIMAL(10, 2),
    utilization_rate    DECIMAL(10, 4), 
    PRIMARY KEY (truck_id, month_start_date)
);
GO


-- 14. TRUCKS
IF OBJECT_ID('silver.trucks', 'U') IS NOT NULL DROP TABLE silver.trucks;
GO
CREATE TABLE silver.trucks (
    truck_id              VARCHAR(20) PRIMARY KEY,
    unit_number           VARCHAR(20),
    make                  VARCHAR(50),
    model_year            INT,
    vin                   VARCHAR(50),
    acquisition_date      DATE,
    acquisition_mileage   INT,
    fuel_type             VARCHAR(20),
    tank_capacity_gallons INT, 
    status                VARCHAR(20),
    home_terminal         VARCHAR(100)
);
GO
